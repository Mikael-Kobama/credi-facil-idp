{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LoanPackageOutput",
  "type": "object",
  "properties": {
    "package_id": { "type": "string", "format": "uuid" },
    "status": { "type": "string", "enum": ["PROCESSING", "NEEDS_REVIEW", "COMPLETED", "FAILED"] },
    "confianca_geral": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "revisao_humana": { "type": "boolean" },
    "documentos": {
      "type": "object",
      "properties": {
        "identidade": {
          "type": "object",
          "properties": {
            "nome": { "type": "string" },
            "documento_identificacao": { "type": "string" },
            "data_nascimento": { "type": "string", "format": "date" },
            "confianca": { "type": "number" }
          },
          "required": ["nome", "documento_identificacao", "data_nascimento", "confianca"]
        }
      },
      "required": ["identidade"]
    }
  },
  "required": ["package_id", "status", "confianca_geral", "revisao_humana", "documentos"]
}