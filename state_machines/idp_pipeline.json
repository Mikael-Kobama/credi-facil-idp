{
  "Comment": "Pipeline simplificado e robusto de IDP para o CrediFacil",
  "StartAt": "InvokeBDA",
  "States": {
    "InvokeBDA": {
      "Type": "Task",
      "Resource": "${BdaInvokerArn}",
      "Next": "WaitForBDA"
    },
    "WaitForBDA": {
      "Type": "Wait",
      "Seconds": 10,
      "Next": "GetBDAStatus"
    },
    "GetBDAStatus": {
      "Type": "Task",
      "Resource": "${BdaStatusPollerArn}",
      "Next": "CheckBDAStatus"
    },
    "CheckBDAStatus": {
      "Type": "Choice",
      "Choices": [
        {
          "Variable": "$.status",
          "StringEquals": "SUCCESS",
          "Next": "StructureWithNova"
        },
        {
          "Variable": "$.status",
          "StringEquals": "FAILED",
          "Next": "NotifyError"
        }
      ],
      "Default": "WaitForBDA"
    },
    "StructureWithNova": {
      "Type": "Task",
      "Resource": "${NovaStructurerArn}",
      "Next": "WriteResult"
    },
    "WriteResult": {
      "Type": "Task",
      "Resource": "${ResultWriterArn}",
      "Next": "NotifySuccess"
    },
    "NotifySuccess": {
      "Type": "Task",
      "Resource": "${NotificationArn}",
      "End": true
    },
    "NotifyError": {
      "Type": "Task",
      "Resource": "${NotificationArn}",
      "End": true
    }
  }
}